# AG Lex — root-level env consumed by docker-compose.yml.
# Copy to `.env` and fill in real values. The `.env` file is gitignored.
#
# legal_app/.env.example is the more detailed reference for the same set of
# backend variables; this file is intentionally short so docker compose pulls
# only what it needs to wire into the backend container.

# --- Anthropic / Claude ---
# Required for any AI-backed phase (contract analysis, reconciliation, etc.).
API_KEY=
# Override only when you need a non-default model (see docs.claude.com).
MODEL_NAME=claude-sonnet-4-6

# --- Auth ---
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# --- Embeddings ---
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Display-PDF pipeline (Phase 4.x) ---
# Container ships LibreOffice at /usr/bin/soffice — usually no override needed.
DISPLAY_PDF_TIMEOUT=30
MAX_DISPLAY_PDF_BYTES=41943040
