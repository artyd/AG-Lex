# AG Lex backend secrets/config. Copy to .env (never commit .env).

# Anthropic — required for Claude-powered phases (1.4+).
API_KEY=

# Claude model id. Check docs.claude.com for current names.
MODEL_NAME=claude-sonnet-4-6

# SQLite database path (defaults to legal_app/database/legal.sqlite).
DB_PATH=

# JWT signing secret for auth (Phase 2.1). Generate via `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
JWT_SECRET=

# Sentence-Transformer model id for embeddings (Phase 1.1+).
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Folder containing the built Vite frontend. Default: ../dist relative to legal_app/.
FRONTEND_DIR=

# --- Phase 4.x: display-PDF pipeline ----------------------------------------
# LibreOffice headless converter used to render DOCX/XLSX → PDF for the
# pixel-perfect FE view. Default `soffice` resolves via PATH. Install on
# Debian/Ubuntu with:
#   apt-get install --no-install-recommends \
#     libreoffice-core libreoffice-writer libreoffice-calc \
#     fonts-noto fonts-noto-cjk
# (Noto fonts matter for Ukrainian / CJK glyphs — without them soffice
# substitutes □ boxes.)
#
# Pitfall: even after a successful apt install, `which soffice` from inside
# the aglex systemd unit can return None if the unit's PATH excludes
# /usr/bin or hardens with ProtectSystem=strict / PrivateUsers. The backend
# now probes a tight list of canonical install paths as a fallback, so a
# vanilla install Just Works. Set this var only when LibreOffice is in a
# non-standard location, e.g.:
#   SOFFICE_PATH=/usr/bin/soffice
#   SOFFICE_PATH=/usr/lib/libreoffice/program/soffice
#   SOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice  # macOS
#   SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe       # Windows
SOFFICE_PATH=

# Hard timeout per single-doc soffice conversion (seconds).
DISPLAY_PDF_TIMEOUT=30

# Reject rendered PDFs larger than this (bytes). Prevents runaway BLOBs.
# Default 40 MB ≈ 1.5× the upload cap, generous for typical legal docs.
MAX_DISPLAY_PDF_BYTES=41943040
