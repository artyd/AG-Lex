{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git for-each-ref:*)",
      "Bash(git remote -v:*)",
      "Bash(git rev-parse:*)",
      "Bash(git stash list:*)",
      "Bash(git config --get:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run docs:check:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright test --list:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python legal_app/scripts/check_codex.py:*)",
      "Bash(python scripts/generate_docs.py --check:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(curl -fsS http://localhost:8002/api/health:*)",
      "Bash(curl -fsS http://127.0.0.1:8001/api/health:*)",
      "Bash(wc -l:*)",
      "Bash(ls:*)",
      "Bash(node -e:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npx playwright install:*)",
      "Bash(npx playwright test:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose build:*)",
      "Bash(docker compose restart:*)",
      "Bash(docker compose down:*)",
      "Bash(uvicorn:*)",
      "Bash(./deploy.sh:*)",
      "Edit(legal_app/backend/auth.py)",
      "Edit(legal_app/backend/rbac.py)",
      "Edit(legal_app/backend/cases_acl.py)",
      "Edit(legal_app/backend/prompts.py)",
      "Edit(legal_app/backend/claude_client.py)",
      "Edit(legal_app/backend/contract_analysis.py)",
      "Edit(legal_app/backend/reconciliation.py)",
      "Edit(legal_app/backend/lawyer_chat.py)",
      "Edit(legal_app/backend/database.py)",
      "Edit(legal_app/backend/models.py)",
      "Edit(legal_app/backend/realtime.py)",
      "Edit(docker/backend.Dockerfile)",
      "Edit(docker-compose.yml)",
      "Edit(.github/workflows/deploy.yml)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(legal_app/.env)",
      "Read(legal_app/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_rsa*)",
      "Edit(./.env)",
      "Edit(legal_app/.env)"
    ]
  }
}
